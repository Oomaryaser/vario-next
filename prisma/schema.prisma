// prisma/schema.prisma

// 1. تعريف كيفية الاتصال بقاعدة البيانات
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 2. توليد عميل Prisma تلقائيًا
generator client {
  provider = "prisma-client-js"
}

// 3. نماذج البيانات مع العلاقات الكاملة

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  role      String   @default("customer")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // حقل عكسي لربط كل طلبات هذا المستخدم
  orders Order[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  createdAt   DateTime @default(now())

  // حقل عكسي لربط كل العناصر-الطلبات الخاصة بهذا المنتج
  orderProducts OrderProduct[]
}

model Order {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  total     Float
  status    String   @default("pending")
  createdAt DateTime @default(now())

  // حقل عكسي لربط كل منتجات هذا الطلب
  orderItems OrderProduct[]
}

model OrderProduct {
  id        Int     @id @default(autoincrement())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  quantity  Int     @default(1)
}
